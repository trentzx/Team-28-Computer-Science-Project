<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.campusbooking.controllers.UserManagementController"
      spacing="12" style="-fx-padding: 20; -fx-background-color: #f9f9f9;">

    <Label text="User Management" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

    <!-- ── Add User Form ──────────────────────────────────────────────── -->
    <Label text="Add New User" style="-fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="userIdField"   promptText="User ID"   prefWidth="100"/>
        <TextField fx:id="nameField"     promptText="Full Name" prefWidth="150"/>
        <TextField fx:id="emailField"    promptText="Email"     prefWidth="180"/>
        <ComboBox  fx:id="userTypeCombo" promptText="Type"      prefWidth="110"/>
        <Button text="Add User" onAction="#handleAddUser"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
    </HBox>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill: red;"/>

    <Separator/>

    <!-- ── View User Details ─────────────────────────────────────────── -->
    <Label text="View User Details" style="-fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="viewUserIdField" promptText="User ID to look up" prefWidth="200"/>
        <Button text="View Details" onAction="#handleViewUserDetails"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    </HBox>

    <Label fx:id="detailsLabel" text="" wrapText="true"
           style="-fx-font-family: monospace; -fx-background-color: #eef; -fx-padding: 10; -fx-min-height: 120;"/>

    <Separator/>

    <!-- ── All Users Table ───────────────────────────────────────────── -->
    <Label text="All Users" style="-fx-font-weight: bold;"/>
    <TableView fx:id="userTableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colUserId" text="User ID"  prefWidth="90"/>
            <TableColumn fx:id="colName"   text="Name"     prefWidth="160"/>
            <TableColumn fx:id="colEmail"  text="Email"    prefWidth="220"/>
            <TableColumn fx:id="colType"   text="Type"     prefWidth="90"/>
        </columns>
    </TableView>

</VBox>
