<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns:fx="http://javafx.com/fxml" spacing="10" style="-fx-padding: 20;">
    <Label text="User Management" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <Label text="Add User"/>
    <HBox spacing="10">
        <TextField fx:id="userIdField" promptText="User ID"/>
        <TextField fx:id="nameField" promptText="Name"/>
        <TextField fx:id="emailField" promptText="Email"/>
        <ComboBox fx:id="userTypeCombo" promptText="Type"/>
        <Button text="Add User"/>
    </HBox>
    <Label text="All Users"/>
    <TableView fx:id="userTable">
        <columns>
            <TableColumn text="User ID"/>
            <TableColumn text="Name"/>
            <TableColumn text="Email"/>
            <TableColumn text="Type"/>
        </columns>
    </TableView>
</VBox>